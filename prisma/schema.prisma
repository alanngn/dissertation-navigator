generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id
  email          String   @unique
  name           String
  role           String   @default("user")
  activePresetId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  presets InstructionPreset[]
}

/// Singleton platform governance settings inherited by every agent at runtime.
model PlatformSettings {
  id        String   @id @default("platform")
  version   String   @default("1.0")
  preamble  String   @default("") @db.Text
  /// Platform rules as JSON array of { text, priority: "critical" | "moderate" }.
  rules     Json     @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model InstructionPreset {
  id               String   @id
  userId           String
  name             String
  purpose          String   @default("") @db.Text
  businessFunction String   @default("") @db.Text
  /// Agent rules as JSON array of { text, priority: "critical" | "moderate" }.
  rules            Json     @default("[]")
  content          String   @db.Text
  updatedAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditRun {
  id           String   @id
  slug         String   @unique
  userId       String?
  fileName     String
  agentsRun    Int
  agentsFailed Int
  redTotal     Int
  yellowTotal  Int
  greenTotal   Int
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  agentResults AuditAgentResult[]

  @@index([userId])
  @@index([slug])
}

model AuditAgentResult {
  id         String  @id
  auditRunId String
  agentId    String
  agentName  String
  status     String
  summary    String  @default("") @db.Text
  rawOutput  String  @default("") @db.Text
  error      String? @db.Text

  auditRun AuditRun       @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  findings AuditFinding[]

  @@index([auditRunId])
}

model AuditFinding {
  id            String  @id
  agentResultId String
  severity      String
  title         String
  detail        String  @db.Text
  example       String? @db.Text

  agentResult AuditAgentResult @relation(fields: [agentResultId], references: [id], onDelete: Cascade)

  @@index([agentResultId])
}
