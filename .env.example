# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Pooled PostgreSQL URL for the app runtime (serverless / connection pooler).
# Without DATABASE_URL, presets continue to use browser localStorage only.
# Neon on Vercel: provided automatically as DATABASE_URL
DATABASE_URL=

# Direct PostgreSQL URL for Prisma migrations (no pooler).
# Required on Vercel so `prisma migrate deploy` can run during build.
# Neon on Vercel: provided automatically as DATABASE_URL_UNPOOLED
# Local: can match DATABASE_URL when not using a pooler.
DATABASE_URL_UNPOOLED=
